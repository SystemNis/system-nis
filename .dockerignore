# Local environment — Railway provides env vars directly, never bake .env into the image
.env
.env.*
!.env.example

# Local SQLite database — Railway uses a managed MySQL/Postgres plugin instead
database/database.sqlite

# Dependency directories — installed fresh inside the container
/vendor
/node_modules

# Version control & IDE
.git
.gitignore
.idea
.vscode

# Local dev tooling
/storage/logs/*.log
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/views/.gitignore

# OS noise
.DS_Store
Thumbs.db

# Docs not needed at runtime
*.md
!README.md
